run = "pip install -r requirements.txt && playwright install chromium && python app.py"
language = "python3"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "gunicorn app:app --bind 0.0.0.0:${PORT:-5000} --timeout 180 --workers 2"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 5000
externalPort = 80
